# Copiar a .env y completar valores reales (no subir .env al repositorio)
# cp .env.example .env
#
# MySQL compartido: deploy/docker-compose-mysql.yml (contenedor mysql-server)

# --- Base de datos (local dev → bd_adm_club_desa) ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/bd_adm_club_desa?serverTimezone=America/Santiago&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=Mysql.mysql

# validate = solo comprueba esquema (recomendado tras init SQL)
SPRING_JPA_DDL_AUTO=validate

# --- App ---
APP_PUBLIC_URL=http://localhost:8081
SERVER_PORT=80
APP_CONTAINER_NAME=adminclub-app-local
APP_HOST_PORT=8081

# Imagen Docker Hub (CI/CD)
DOCKER_IMAGE=tuusuario/mi-club:desa

# --- MySQL compartido (solo para deploy/docker-compose-mysql.yml en VPS) ---
MYSQL_ROOT_PASSWORD=cambiar_root

# --- Correo SMTP ---
MAIL_FROM=test@ircd.cl
SPRING_MAIL_HOST=mail.ircd.cl
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=test@ircd.cl
SPRING_MAIL_PASSWORD=tu_password_ircd

# --- Khipu ---
KHIPU_MERCHANT_SECRET=
KHIPU_WEBHOOK_VERIFY_SIGNATURE=true

# --- Admin ---
ADMIN_SOPORTE_ENABLED=false
NOTIFICATIONS_SCHEDULER_ENABLED=true
