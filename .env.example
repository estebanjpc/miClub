# Copiar a .env y completar valores reales (no subir .env al repositorio)
# cp .env.example .env

# --- Base de datos ---
MYSQL_ROOT_PASSWORD=cambiar_root
MYSQL_DATABASE=bd_adm_club
MYSQL_USER=adminclub
MYSQL_PASSWORD=cambiar_password

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/bd_adm_club?serverTimezone=America/Santiago&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=adminclub
SPRING_DATASOURCE_PASSWORD=cambiar_password

# validate = solo comprueba esquema (recomendado tras init SQL)
# update = Hibernate aplica cambios (solo transición inicial)
SPRING_JPA_DDL_AUTO=validate

# --- App ---
APP_PUBLIC_URL=https://adminclub.cl
SERVER_PORT=8080

# --- Correo SMTP (IRCD — por ahora; luego migrar a @adminclub.cl) ---
MAIL_FROM=test@ircd.cl
SPRING_MAIL_HOST=mail.ircd.cl
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=test@ircd.cl
SPRING_MAIL_PASSWORD=tu_password_ircd

# --- Khipu (opcional global; cada club puede tener credenciales propias) ---
KHIPU_MERCHANT_SECRET=
KHIPU_WEBHOOK_VERIFY_SIGNATURE=true

# --- Admin ---
ADMIN_SOPORTE_ENABLED=false
NOTIFICATIONS_SCHEDULER_ENABLED=true
