# Copiar a /root/admin-club/desa/.env
# MySQL compartido: contenedor mysql-server, red shared-db-net

DOCKER_IMAGE=tuusuario/mi-club:desa
APP_CONTAINER_NAME=app-club-desa
APP_HOST_PORT=8080
# Por IP: http://45.7.229.27:8080  |  Con subdominio: https://desa.adminclub.cl
APP_PUBLIC_URL=http://45.7.229.27:8080
SERVER_PORT=80

SPRING_DATASOURCE_URL=jdbc:mysql://mysql-server:3306/bd_adm_club_desa?serverTimezone=America/Santiago&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=Mysql.mysql
SPRING_JPA_DDL_AUTO=validate

MAIL_FROM=test@ircd.cl
SPRING_MAIL_HOST=mail.ircd.cl
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=test@ircd.cl
SPRING_MAIL_PASSWORD=tu_password_ircd

KHIPU_MERCHANT_SECRET=
KHIPU_WEBHOOK_VERIFY_SIGNATURE=true
ADMIN_SOPORTE_ENABLED=false
NOTIFICATIONS_SCHEDULER_ENABLED=true
